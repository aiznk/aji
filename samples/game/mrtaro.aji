            }
        },
    ]
end

struct TitleScene:
    extract(Scene)
    items = ["Start", "Exit"]
    index = 0

    met update(self):
        cmd = inputCmd("command > ")
        return self.consumeCmd(cmd)
    end

    met consumeCmd(self, cmd):
        if cmd == Cmd.EOF:
            return false, self
        elif cmd == Cmd.S:
            self.index += 1
            if self.index >= len(self.items):
                self.index = 0
            end
        elif cmd == Cmd.W:
            self.index -= 1
            if self.index < 0:
                self.index = len(self.items) - 1
            end
        elif cmd == Cmd.ENTER:
            item = self.items[self.index]
            if item == "Start":
                return true, FirstScene()
            elif item == "Exit":
                return false, self
            end
        end

        return true, self
    end

    met draw(self):
        for i = 0; i < len(self.items); i += 1:
            print("*", self.items[i])
            if i == self.index:
                puts(" <--")
            else:
                puts()
            end
        end
    end
end

struct Game:
    curScene = nil

    def new():
        self = Game()
        self.curScene = TitleScene()
        return self
    end

    met title(self):
        puts(
"*****************
*    Mr Taro    *
*****************")
    end

    met update(self):
        ok, self.curScene = self.curScene.update()
        return ok
    end

    met draw(self):
        self.curScene.draw()
    end
end

def main():
    game = Game.new()
    game.title()
    game.draw()

    for game.update():
        game.draw()
    end
end

main()

@}
