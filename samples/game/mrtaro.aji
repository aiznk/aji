{@

enum Cmd:
    EOF = -1
    UNKNOWN
    A
    S
    D
    W
    ENTER
    ONE
    TWO
    THREE
end

def inputCmd(prompt):
    print(prompt)

    cmd = ""
    for:
        c = stdin.read(1)
        if c == -1:
            cmd = -1
            break
        end

        cmd += c
        if c == "\n":
            break
        end
    end

    if cmd == -1:
        cmd = Cmd.EOF
    elif cmd == "s\n":
        cmd = Cmd.S
    elif cmd == "w\n":
        cmd = Cmd.W
    elif cmd == "a\n":
        cmd = Cmd.A
    elif cmd == "d\n":
        cmd = Cmd.D
    elif cmd == "\n":
        cmd = Cmd.ENTER
    elif cmd == "1\n":
        cmd = Cmd.ONE
    elif cmd == "2\n":
        cmd = Cmd.TWO
    elif cmd == "3\n":
        cmd = Cmd.THREE
    else:
        cmd = Cmd.UNKNOWN
    end

    return cmd
end

struct Scene:
    prot = []
    protIndex = 0
    loop = true
    lastResult = true
    nextScene = nil

    met line(self):
        puts("--------------------------------------------------")
    end

    met update(self):
        if not self.loop:
            return self.lastResult, self.nextScene
        end

        cmd = inputCmd("command > ")
        if cmd == Cmd.EOF:
            return false, self
        elif cmd == Cmd.ENTER:
            self.protIndex += 1
            if self.protIndex >= len(self.prot):
                return false, self
            end
        end
        return true, self
    end

    met draw(self):
        prot = self.prot[self.protIndex]
        self.line()
        puts(prot.text)
        puts()

        if has(prot, "choices"):
            if self.consumeChoices(prot):
                puts(prot.ok.text)
                self.loop = false
                self.nextScene = prot.ok.nextScene
            else:
                puts(prot.fail.text)
                self.loop = false
                self.nextScene = prot.fail.nextScene
            end
        else:
            puts("v Enter")
        end

        self.line()
    end

    met consumeChoices(self, prot):
        for i = 0; i < len(prot.choices); i += 1:
            puts(prot.choices[i])
        end
        puts()

        for:
            n = 0
            cmd = inputCmd("number > ")
            if cmd == Cmd.EOF:
                self.loop = false
            elif cmd == Cmd.ONE:
                n = 1
            elif cmd == Cmd.TWO:
                n = 2
            elif cmd == Cmd.THREE:
                n = 3
            else:
                continue
            end

            return prot.hope == n
            break
        end
    end
end

