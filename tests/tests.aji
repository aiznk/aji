from "tests/lib/sort.aji" import main as sortMain
from "tests/lib/textfile.aji" import main as textFileMain
from "tests/lib/unix.aji" import main as unixMain
from "tests/data/dict.aji" import main as dictMain
from "tests/data/vector.aji" import main as vecMain
from "tests/closure/closure.aji" import main as closureMain
from "tests/blocks/blocks.aji" import main as blocksMain
from "tests/other/other.aji" import main as otherMain

cases = {
    "expr": exprMain,
    "ptr": ptrMain,
    "chainExpr": chainExprMain,
    "forStmt": forStmtMain,
    "ifStmt": ifStmtMain,
    "globalStmt": globalStmtMain,
    "nonlocalStmt": nonlocalStmtMain,
    "throwStmt": throwStmtMain,
    "tryCatchStmt": tryCatchStmtMain,
    "importStmt": importStmtMain,
    "delStmt": delStmtMain,
    "injectBlockStmt": injectBlockStmtMain,
    "func": funcMain,
    "struct": structMain,
    "enum": enumMain,
    "types": typesMain,
    "mi": miMain,
    "functions": functionsMain,
    "os": osMain,
    "io": ioMain,
    "unicode": unicodeMain,
    "bytes": bytesMain,
    "lib": libMain,
    "listMain": listMain,
    "html": htmlMain,
    "resource": resourceMain,
    "csv": csvMain,
    "file": fileMain,
    "fileUtils": fileUtilsMain,
    "text": textMain,
    "sort": sortMain,
    "textFile": textFileMain,
    "unix": unixMain,
    "dict": dictMain,
    "vec": vecMain,
    "closure": closureMain,
    "blocks": blocksMain,
    "other": otherMain,
}

def allTest():
    keys = cases.keys()
    for i = 0; i < len(keys); i += 1:
        funcName = keys[i]
        puts("Test $funcName")
        cases[funcName]("all")
    end
end

def showList():
    keys = cases.keys()
    for i = 0; i < len(keys); i += 1:
        funcName = keys[i]
        puts(funcName)
    end
end

def main():
    name = opts.args(1) or "all"
    case = opts.args(2) or "all"

    if name == "list":
        return showList()
    end

    keys = cases.keys()
    for i = 0; i < len(keys); i += 1:
        funcName = keys[i]
        if name == "all":
            cases[funcName]("all")            
        elif funcName == name:
            cases[funcName](case)
            break
        end
    end
end

main()

@}
