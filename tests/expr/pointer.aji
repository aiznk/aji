def caseExpr():
    a = "abc"
    p = &a

    try: 
        p += 1
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "invalid left hand operand (18)")
    end

    try: 
        p -= 1
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "invalid left hand operand type (18)")
    end

    try: 
        p *= 1
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "invalid left hand operand (18)")
    end

    try: 
        p /= 1
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "invalid left hand operand")
    end

    try: 
        p %= 1
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "invalid left hand operand")
    end

    try:
        assert((a == p) == false)
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "invalid right hand operand")
    end

    try:
        assert((a != p) == true)
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "invalid right hand operand")
    end

    try:
        assert((a > p) == false)
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "can't compare with gt")
    end

    try:
        assert((a >= p) == false)
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "can't compare with gte")
    end

    try:
        assert((a < p) == false)
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "can't compare with lt (5)")
    end

    try:
        assert((a <= p) == false)
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "can't compare with lte")
    end

    try:
        assert((&a == p) == true)
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "invalid left hand operand (18)")
    end

    try:
        assert(not p == false)
        assert(0 and "error")
    catch TypeError as e:
        assert(e.what() == "invalid left hand operand (18)")
    end
end

cases = {
    "ptr": casePtr,
    "ptrAndStruct": casePtrAndStruct,
    "ptrLifeTime": casePtrLifeTime,
    "ptrAndLocalVar": casePtrAndLocalVar,
    "ptrAndVec": casePtrAndVec,
    "ptrAndVecPush": casePtrAndVecPush,
    "ptrAndVecInsert": casePtrAndVecInsert,
    "ptrAndDict": casePtrAndDict,
    "ptrAndDictAssign": casePtrAndDictAssign,
    "ptrAndStructAssign": casePtrAndStructAssign,
    "ptrAndVecExtend": casePtrAndVecExtend,
    "ptrAndFor": casePtrAndFor,
    "ptrAndIf": casePtrAndIf,
    "expr": caseExpr,
    "etc": caseEtc,
}

def main(case):
    from "tests/utils" import run
    run(case, cases)
end
@}
