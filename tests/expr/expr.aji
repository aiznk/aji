        /* int, object */ [0, o, TypeError], [o, 0, TypeError],
        /* int, def-struct */ [0, S, TypeError], [S, 0, TypeError],
        /* int, def */ [0, func, TypeError], [func, 0, TypeError],
        /* int, nil */ [0, nil, TypeError], [nil, 0, TypeError],
        /* int, ring-object */ [0, ro, true], [ro, 0, false],
