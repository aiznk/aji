    // identifier, identifier
    b = 1

    a = b >= b
    assert(a == true)
end


def caseLt():
    puts("$header <")

    /******
    * Int *
    ******/
    
    // int, int
    a = 2 < 2
    assert(a == false)

    a = 1 < 2
    assert(a == true)

    a = 1 < 2 < 3
    assert(a == true)

    a = 1 < 1 < 0
    assert(a == false)

    // int, float
    a = 3.14 < 1
    assert(a == false)

    a = 1 < 3.14
    assert(a == true)

    a = 3.14 < 1 < 2.3
    assert(a == true)

    // int, string
    try:
        a = "abc" < 1
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1 < "abc"
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = "abc" < 1 < "def"
        assert(0 and "hige")
    catch TypeError:
    end

    // int, vec
    vec = []

    try:
        a = vec < 1  
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1 < vec
        assert(0 and "hige")
    catch TypeError:
    end

    // int, dict
    d = {}

    try:
        a = d < 1  // Dict is empty. this mean to zero
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1 < d
        assert(0 and "hige")
    catch TypeError:
    end

    // int, object
    struct S: end
    s = S()

    try:
        a  = s < 1
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1 < s
        assert(0 and "hige")
    catch TypeError:
    end

    // int, def-struct
    struct S: end

    try:
        a = S < 1
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1 < S
        assert(0 and "hige")
    catch TypeError:
    end

    // int, def
    def func(): end

    try:
        a = func < 1
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1 < func
        assert(0 and "hige")
    catch TypeError:
    end

    // int, nil
    try:
        a = nil < 1
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1 < nil
        assert(0 and "hige")
    catch TypeError:
    end

    // int, ring-object
    d = { v: 2 }

    a = 1 < d.v
    assert(a == true)

    a = d.v < 1
    assert(a == false)

    // int, identifier
    b = 2

    a = 1 < b
    assert(a == true)

    a = b < 2
    assert(a == false)

    /********
    * Float *
    ********/
    
    // float, int
    a = 1.2 < 2
    assert(a == true)

    a = 1.0 < 1
    assert(a == false)

    a = 1.0 < 1.0 < 1
    assert(a == true)

    a = 1.0 < 1.0 < 0
    assert(a == false)

    // float, float
    a = 3.14 < 3.14
    assert(a == false)

    a = 1 < 3.14
    assert(a == true)

    a = 3.14 < 3.14 < 2.3
    assert(a == true)

    // float, string
    try:
        a = "abc" < 1.2
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1.2 < "abc"
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = "abc" < 1.2 < "def"
        assert(0 and "hige")
    catch TypeError:
    end

    // float, vec
    vec = []

    try:
        a = vec < 1.2  
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1.2 < vec
        assert(0 and "hige")
    catch TypeError:
    end

    // float, dict
    d = {}

    try:
        a = d < 1.2  // Dict is empty. this mean to zero
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1.2 < d
        assert(0 and "hige")
    catch TypeError:
    end

    // float, object
    struct S: end
    s = S()

    try:
        a = s < 1.2
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1.2 < s
        assert(0 and "hige")
    catch TypeError:
    end

    // float, def-struct
    struct S: end

    try:
        a = S < 1.2
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1.2 < S
        assert(0 and "hige")
    catch TypeError:
    end

    // float, def
    def func(): end

    try:
        a = func < 1.2
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1.2 < func
        assert(0 and "hige")
    catch TypeError:
    end

    // float, nil
    try:
        a = nil < 1.2
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 1 < nil
        assert(0 and "hige")
    catch TypeError:
    end

    // float, ring-object
    d = { v: 2.2 }

    a = 1.2 < d.v
    assert(a == true)

    a = d.v < 2.2
    assert(a == false)

    // float, identifier
    b = 2.2

    a = 1.2 < b
    assert(a == true)

    a = b < 2.2
    assert(a == false)

    /*********
    * String *
    *********/
    
    // string, int
    try:
        a = "abc" < 2
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = "abc" < 1
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = "abc" < "abc" < 1
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = "abc" < "abc" < 0
        assert(0 and "hige")
    catch TypeError:
    end

    // string, float
    try:
        a = "abc" < 3.14
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = 3.14 < "abc"
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = "abc" < 3.14 < 2.3
        assert(0 and "hige")
    catch TypeError:
    end

    // string, string
    try:
        a = "abc" < "abc"
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = "def" < "abc"
