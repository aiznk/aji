    catch TypeError:
    end

    try:
        a = [] > func
        assert(0 and "hige")
    catch TypeError:
    end

    // vec, nil
    try:
        a = nil > []
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = [] > nil
        assert(0 and "hige")
    catch TypeError:
    end

    // vec, ring-object
    d = { v: 2 }

    try:
        a = [] > d.v
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = d.v > []
        assert(0 and "hige")
    catch TypeError:
    end

    // vec, identifier
    b = 2

    try:
        a = [] > b
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = b > []
        assert(0 and "hige")
    catch TypeError:
    end

    /*******
    * Dict *
    *******/

    // dict, int
    // @see Int

    // dict, float
    // @see Float

    // dict, string
    // @see String

    // dict, vec
    // @see Vec

    // dict, dict
    d = {}
    try:
        a = d > {}  // Dict is empty. this mean to zero
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = {} > d
        assert(0 and "hige")
    catch TypeError:
    end

    // dict, object
    struct S: end
    s = S()

    try:
        a  = s > {}
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = {} > s
        assert(0 and "hige")
    catch TypeError:
    end

    // dict, def-struct
    struct S: end

    try:
        a = S > {}
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = {} > S
        assert(0 and "hige")
    catch TypeError:
    end

    // dict, def
    def func(): end

    try:
        a = func > {}
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = {} > func
        assert(0 and "hige")
    catch TypeError:
    end

    // dict, nil
    try:
        a = nil > {}
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = {} > nil
        assert(0 and "hige")
    catch TypeError:
    end

    // dict, ring-object
    d = { v: 2 }

    try:
        a = {} > d.v
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = d.v > {}
        assert(0 and "hige")
    catch TypeError:
    end

    // dict, identifier
    b = 2

    try:
        a = {} > b
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = b > {}
        assert(0 and "hige")
    catch TypeError:
    end

    /*********
    * Object *
    *********/

    // object, int
    // @see Int

    // object, float
    // @see Float

    // object, string
    // @see String

    // object, vec
    // @see Vec

    // object, dict
    // @see Dict

    // object, object
    struct S: end
    s = S()

    try:
        a  = s > s
        assert(0 and "hige")
    catch TypeError:
    end

    s2 = S()
    try:
        a = s2 > s
        assert(0 and "hige")
    catch TypeError:
    end

    // object, def-struct
    struct S: end
    s = S()

    try:
        a = S > s
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = s > S
        assert(0 and "hige")
    catch TypeError:
    end

    // object, def
    def func(): end

    try:
        a = func > s
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = s > func
        assert(0 and "hige")
    catch TypeError:
    end

    // object, nil
    try:
        a = nil > s
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = s > nil
        assert(0 and "hige")
    catch TypeError:
    end

    // object, ring-object
    d = { v: 2 }

    try:
        a = s > d.v
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = d.v > s
        assert(0 and "hige")
    catch TypeError:
    end

    // object, identifier
    b = 2

    try:
        a = s > b
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = b > s
        assert(0 and "hige")
    catch TypeError:
    end

    /*************
    * Def Struct *
    *************/

    // def-struct, int
    // @see Int

    // def-struct, float
    // @see Float

    // def-struct, string
    // @see String

    // def-struct, vec
    // @see Vec

    // def-struct, dict
    // @see Dict

    // def-struct, object
    // @see Object

    // def-struct, def-struct
    struct S: end

    try:
        a = S > S
        assert(0 and "hige")
    catch TypeError:
    end

    // def-struct, def
    def func(): end

    try:
        a = func > S
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = S > func
        assert(0 and "hige")
    catch TypeError:
    end

    // def-struct, nil
    try:
        a = nil > S
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = S > nil
        assert(0 and "hige")
    catch TypeError:
    end

    // def-struct, ring-object
    d = { v: 2 }

    try:
        a = S > d.v
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = d.v > S
        assert(0 and "hige")
    catch TypeError:
    end

    // def-struct, identifier
    b = 2

    try:
        a = S > b
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = b > S
        assert(0 and "hige")
    catch TypeError:
    end

    /******
    * Def *
    ******/

    // def, int
    // @see Int

    // def, float
    // @see Float

    // def, string
    // @see String

    // def, vec
    // @see Vec

    // def, dict
    // @see Dict

    // def, object
    // @see Object

    // def, def-struct
    // @see Def Struct

    // def, def
    def func(): end

    try:
        a = func > func
        assert(0 and "hige")
    catch TypeError:
    end

    // def, nil
    try:
        a = nil > func
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = func > nil
        assert(0 and "hige")
    catch TypeError:
    end

    // def, ring-object
    d = { v: 2 }

    try:
        a = func > d.v
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = d.v > func
        assert(0 and "hige")
    catch TypeError:
    end

    // def, identifier
    b = 2

    try:
        a = func > b
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = b > func
        assert(0 and "hige")
    catch TypeError:
    end

    /******
    * Nil *
    ******/

    // nil, int
    // @see Int

    // nil, float
    // @see Float

    // nil, string
    // @see String

    // nil, vec
    // @see Vec

    // nil, dict
    // @see Dict

    // nil, object
    // @see Object

    // nil, def-struct
    // @see Def Struct

    // nil, def
    // @see Def

    // nil, nil
    try:
        a = nil > nil
        assert(0 and "hige")
    catch TypeError:
    end

    // nil, ring-object
    d = { v: 2 }

    try:
        a = nil > d.v
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = d.v > nil
        assert(0 and "hige")
    catch TypeError:
    end

    // nil, identifier
    b = 2

    try:
        a = nil > b
        assert(0 and "hige")
    catch TypeError:
    end

    try:
        a = b > nil
        assert(0 and "hige")
    catch TypeError:
    end

    /**************
    * Ring Object *
    **************/

    // ring-object, int
    // @see Int

    // ring-object, float
    // @see Float

    // ring-object, string
    // @see String

    // ring-object, vec
    // @see Vec

    // ring-object, dict
    // @see Dict

    // ring-object, object
    // @see Object

    // ring-object, def-struct
    // @see Def Struct

    // ring-object, def
    // @see Def

    // ring-object, nil
    // @see Nil

    // ring-object, ring-object
    d = { v: 2 }

    a = d.v > d.v
    assert(a == false)

    d2 = { v: 3 }
    a = d2.v > d.v
    assert(a == true)

    // ring-object, identifier
    b = 1

    a = d.v > b
    assert(a == true)

    a = b > d.v
    assert(a == false)

    /*************
    * Identifier *
    *************/

    // identifier, int
    // @see Int

    // identifier, float
    // @see Float

    // identifier, string
    // @see String

    // identifier, vec
    // @see Vec

    // identifier, dict
    // @see Dict

    // identifier, object
    // @see Object

    // identifier, def-struct
    // @see Def Struct

    // identifier, def
    // @see Def

    // identifier, nil
    // @see Nil

    // identifier, ring-object
    // @see Ring Object

    // identifier, identifier
    b = 1

    a = b > b
    assert(a == false)

    c = 2
    a = c > b
    assert(a == true)
end

def caseAdd():
    puts("$header caseAdd")

    // Int, Int
    assert(1 + 1 == 2)
    assert(1 + 1 + 1 == 3)

    // Int, Float
    assert(1 + 1.2 == 2.2)
    assert(1 + 1.2 + 2.3 == 4.5)

    // Int, Bool
    assert(false + 1 == 1)
    assert(true + 1 == 2)
    assert(1 + false == 1)
    assert(1 + true == 2)

    // Int, Nil
    try:
        1 + nil
    catch TypeError as e:
        assert(e.what() == "can't add with int")
    end

    try:
        nil + 1
    catch TypeError as e:
        assert(e.what() == "can't add")
    end

    // Int, Str
    try:
        1 + "a"
    catch TypeError as e:
        assert(e.what() == "can't add with int")
    end

    try:
        "a" + 1
    catch TypeError as e:
        assert(e.what() == "can't add 1 with string")
    end

    // Int, Struct
    struct S: end

    try:
        1 + S
    catch TypeError as e:
        assert(e.what() == "can't add with int")
    end

    try:
        S + 1
    catch TypeError as e:
        assert(e.what() == "can't add")
    end

    o = S()

    try:
        1 + o
    catch TypeError as e:
        assert(e.what() == "can't add with int")
    end

    try:
        o + 1
    catch TypeError as e:
        assert(e.what() == "can't add")
    end
end

def caseSub():
    puts("$header caseSub")

    // Int, Int
    assert(1 - 1 == 0)
    assert(1 - 1 - 1 == -1)

    // Int, Float
    
    // TODO: Assertion error
    // puts(1 - 1.2)
    // assert(1 - 1.2 == -0.2)
    
    assert(1 - 0.5 == 0.5)
    assert(1 - 1.2 - 2.3 == -2.5)

    // Int, Bool
    assert(false - 1 == -1)
    assert(true - 1 == 0)
    assert(1 - false == 1)
    assert(1 - true == 0)

    // Int, Nil
    try:
        1 - nil
    catch TypeError as e:
        assert(e.what() == "can't sub with int")
    end

    try:
        nil - 1
    catch TypeError as e:
        assert(e.what() == "can't sub")
    end

    // Int, Str
    try:
        1 - "a"
    catch TypeError as e:
        assert(e.what() == "can't sub with int")
    end

    try:
        "a" - 1
    catch TypeError as e:
        assert(e.what() == "can't sub")
    end

    // Int, Struct
    struct S: end

    try:
        1 - S
    catch TypeError as e:
        assert(e.what() == "can't sub with int")
    end

    try:
        S - 1
    catch TypeError as e:
        assert(e.what() == "can't sub")
    end

    o = S()

    try:
        1 - o
    catch TypeError as e:
        assert(e.what() == "can't sub with int")
    end

    try:
        o - 1
    catch TypeError as e:
        assert(e.what() == "can't sub")
    end
end

def caseMul():
    puts("$header caseMul")

    // Int, Int
    assert(2 * 2 == 4)
    assert(2 * 2 * 2 == 8)

    // Int, Float
    
    assert(1 * 0.5 == 0.5)
    assert(1 * 0.5 * 2.0 == 1.0)

    // Int, Bool
    assert(false * 2 == 0)
    assert(true * 2 == 2)
    assert(2 * false == 0)
    assert(2 * true == 2)

    // Int, Nil
    try:
        1 * nil
    catch TypeError as e:
        assert(e.what() == "can't mul with int")
    end

    try:
        nil * 1
    catch TypeError as e:
        assert(e.what() == "can't mul")
    end

    // Int, Str
    try:
        1 * "a"
    catch TypeError as e:
        assert(e.what() == "can't mul with int")
    end

    try:
        "a" * 1
    catch TypeError as e:
        assert(e.what() == "can't mul")
    end

    // Int, Struct
    struct S: end

    try:
        1 * S
    catch TypeError as e:
        assert(e.what() == "can't mul with int")
    end

    try:
        S * 1
    catch TypeError as e:
        assert(e.what() == "can't mul")
    end

    o = S()

    try:
        1 * o
    catch TypeError as e:
        assert(e.what() == "can't mul with int")
    end

    try:
        o * 1
    catch TypeError as e:
        assert(e.what() == "can't mul")
    end
end

def caseEscape():
    puts("$header caseAdd")

    a = 1 + \
        1
    assert(a == 2)

    a = "abc" + \
        "def"
    assert(a == "abcdef")
end

def main(case):
    from "tests/utils" import run

    run(case, {
        "case1": case1,
        "case2": case2,
        "and": caseAnd,
        "or": caseOr,
        "not": caseNot,
        "eq": caseEq,
        "neq": caseNotEq,
        "lte": caseLtEq,
        "gte": caseGtEq,
        "lt": caseLt,
        "gt": caseGt,
        "add": caseAdd,
        "sub": caseSub,
        "mul": caseMul,
        // "/": caseDiv,
        // "%": caseMod,
        // "+=": caseAddAss,
        // "-=": caseSubAss,
        // "*=": caseMulAss,
        // "/=": caseDivAss,
        // "%=": caseModAss,
        "escape": caseEscape,
    })
end

@}