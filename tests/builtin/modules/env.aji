{@
header = "Test builtin/modules/env"

import "env"

def get():
    puts("$header get")

    try:
        env.get()
        assert(0)
    catch ArgumentsError:
    end

    assert(env.get("HIGE") == nil)
    assert(env.get("HIGE", 1) == 1)
end

cases = {
    "get": get,
}

def allTest():
    puts("$header all")

    keys = cases.keys()
    for i = 0; i < len(keys); i += 1:
        cases[keys[i]]()
    end
end

def main(name):
    puts("$header")

    if name == "all":
        allTest()
    else:
        keys = cases.keys()
        for i = 0; i < len(keys); i += 1:
            key = keys[i]
            if key == name:
                cases[key]()
            end
        end
    end

    puts("Done $header")
end
@}
